PORT=3200

# Workflow generation must come from the configured model.
# Each stage can retry MODEL_MAX_ATTEMPTS times before returning an error.
MODEL_TIMEOUT_MS=120000
MODEL_MAX_ATTEMPTS=3
MODEL_RETRY_DELAY_MS=1500
MODEL_NODE_CONCURRENCY=3

# OpenAI-compatible model config is stored from the UI.
# Default page: http://localhost:3200/workflow.html
# Model config: http://localhost:3200/model-config.html
